.env
CLAUDE.md


# Suggested .gitignore items, see what we need
# =============================================================================
# Secrets and Environment Variables
# =============================================================================
# NEVER commit any file containing real secrets or API keys
# .env
# .env.local
# .env.*.local
# .env.development
# .env.production
# .env.staging
# .env.test
# *.env
# .envrc

# # Only commit the example template
# !.env.example


# # =============================================================================
# # Python (Backend)
# # =============================================================================
# # Bytecode and caches
# __pycache__/
# *.py[cod]
# *$py.class
# *.so

